# ─────────────────────────────────────────────
#  AI Travel Agent – Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────

# Supabase Project URL (found in: Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous/Public Key (found in: Project Settings → API)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Groq API Key (get one free at: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override FastAPI host/port (defaults: 0.0.0.0 / 8000)
# APP_HOST=0.0.0.0
# APP_PORT=8000
